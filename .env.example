# Qdrant runtime settings
RAG_QDRANT_URL=http://localhost:6333
RAG_QDRANT_COLLECTION=code_forensics_knowledge
RAG_QDRANT_TIMEOUT_SEC=30
RAG_REBUILD=1

# Knowledge loading settings
RAG_MAX_PRIMEVUL_RECORDS=0
RAG_NVD_LIVE_ENABLED=1
RAG_NVD_DAYS_BACK=365
RAG_NVD_RESULTS_PER_PAGE=2000
RAG_NVD_PAGES=2

# Optional: set if you have an NVD API key for higher rate limits
NVD_API_KEY=
